CREATE TABLE LanguageEntity (
    idLanguage INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    name TEXT,
    fluencyLevel TEXT
);

insertLanguage:
INSERT INTO LanguageEntity(name, fluencyLevel)
VALUES (?, ?);

getAllLanguages:
SELECT * FROM LanguageEntity;

getLanguageById:
SELECT * FROM LanguageEntity
WHERE idLanguage = ?;

deleteLanguageById:
DELETE FROM LanguageEntity
WHERE idLanguage = ?;