CREATE TABLE Reference (
    id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    name TEXT,
    company TEXT,
    relationship TEXT,
    contactInfo TEXT
);

insertReference:
INSERT INTO Reference(name, company, relationship, contactInfo)
VALUES (?, ?, ?, ?);

getAllReferences:
SELECT * FROM Reference;

getReferenceById:
SELECT * FROM Reference
WHERE id = ?;

deleteReferenceById:
DELETE FROM Reference
WHERE id = ?;